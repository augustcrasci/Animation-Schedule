# Use your own MAL_CLIENT_ID when running collector updates.
# Do not share or commit your real credentials.
# The current read-only collector only requires MAL_CLIENT_ID.
MAL_CLIENT_ID=

# Optional tuning
ANIME_SYNC_START_YEAR=2026
ANIME_SYNC_START_SEASON=spring
ANIME_REFRESH_RECENT_SEASONS=2
ANIME_BACKFILL_PER_RUN=1
ANIME_ENRICH_LINKS_PER_RUN=120
ANIME_FETCH_CREDITS=missing
ANIME_ENRICH_JA_NAMES=missing
ANIME_ENRICH_MAL_PEOPLE_PER_RUN=120
ANIME_ENRICH_MAL_CHARACTERS_PER_RUN=60
ANIME_SYNC_TODAY=2026-03-28
ANIME_VIEWER_PORT=8876
